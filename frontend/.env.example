# 获取您的凭证前往: https://supabase.com/dashboard/project/_/settings/api

# Supabase 项目 URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase 匿名公开密钥 (anon public)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# 打赏 H5 地址，可填写完整 URL 或站内相对地址
# 例如：https://pay.example.com/checkout 或 /donate-h5
VITE_DONATE_H5_URL=http://192.168.2.15:8080
